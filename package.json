{
  "name": "unified-campus-intelligence",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start:all": "node start-all.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0"
  }
}
